<%- include('partials/header') %>

<main>
    <h1>Service Project Categories</h1>

    <ul>
        <% if (categories && categories.length) { %>
            <% categories.forEach(category => { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                </li>
            <% }) %>
        <% } else { %>
            <li>No categories found</li>
        <% } %>
    </ul>
</main>

<%- include('partials/footer') %>   